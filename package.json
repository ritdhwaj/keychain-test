{
  "name": "playwright-pom-framework",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "pretest": "tsc -p .",
    "test": "cross-env playwright test",
    "test:headed": "cross-env PWDEBUG=1 playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "allure:generate": "allure generate --clean ./allure-results -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "codegen": "playwright codegen",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^20.16.5",
    "@types/yargs": "^17.0.33",
    "allure-playwright": "^2.15.1",
    "cross-env": "^7.0.3",
    "playwright": "^1.54.2",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^2.1.1",
    "builder-pattern": "^2.2.0",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "http-status-codes": "^2.3.0",
    "log4js": "^6.9.1",
    "yargs": "^17.7.2"
  }
}
