{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "types": ["node", "@playwright/test"],
    "lib": ["ES2022", "DOM"],
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "strict": true,
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
  },
  "include": ["src", "tests", "data", "playwright.config.ts"]
}
